# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# NextAuth v5 — сгенерировать: npx auth secret (или openssl rand -base64 32)
AUTH_SECRET="your-secret-here"
AUTH_TRUST_HOST=true

# Claude API — ключ для анализа документов (опционально; без него используется stub)
ANTHROPIC_API_KEY=
