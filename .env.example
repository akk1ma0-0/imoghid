# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# NextAuth v5 — сгенерировать: npx auth secret (или openssl rand -base64 32)
AUTH_SECRET="your-secret-here"
AUTH_TRUST_HOST=true

# Claude API — ключ для анализа документов (опционально; без него используется stub)
ANTHROPIC_API_KEY=

# Vercel Blob — хранилище загруженных документов (шаг 2). Создать Blob store в
# Vercel → Storage → Blob; токен нужен и локально, и в проде (иначе загрузка не работает).
BLOB_READ_WRITE_TOKEN=
